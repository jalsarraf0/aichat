# PostgreSQL password (required — do not commit to git)
POSTGRES_PASSWORD=CHANGE_ME

# LM Studio base URL (Windows host running LM Studio)
IMAGE_GEN_BASE_URL=http://host.docker.internal:1234

# Pinned model
IMAGE_GEN_MODEL=liquid/lfm2-24b-a2b

# MinIO S3-compatible object store
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME

# Source preference profile for news/current-events (default, neutral, balanced)
# SOURCE_PROFILE=default
