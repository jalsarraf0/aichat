# ---------------------------------------------------------------------------
# aichat platform — environment variables
# Copy to .env and adjust for your deployment.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# REQUIRED: Set a strong random password (min 32 chars).
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# Bind address for the Postgres port.
# Default (127.0.0.1) is localhost-only. Set to 0.0.0.0 for remote access.
AICHAT_DB_BIND=127.0.0.1

# ---------------------------------------------------------------------------
# aichat-jupyter: code execution API key (optional but recommended)
# ---------------------------------------------------------------------------
# When set, all /exec /sessions endpoints require X-API-Key: <value>
# Generate with: openssl rand -hex 32
# JUPYTER_API_KEY=

# ---------------------------------------------------------------------------
# Intel Arc GPU passthrough (aichat-data, aichat-vision, aichat-docs,
#                             aichat-sandbox, aichat-mcp)
# ---------------------------------------------------------------------------
# Path to the DRI device directory on the host. Usually /dev/dri.
INTEL_DRI_DEVICE=/dev/dri

# Host GID for the "video" group (DRI card access). Find with: getent group video
INTEL_VIDEO_GID=39

# Host GID for the "render" group (renderD128 / OpenCL). Find with: getent group render
INTEL_RENDER_GID=105

# ---------------------------------------------------------------------------
# aichat-mcp: image generation (LM Studio or OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
IMAGE_GEN_BASE_URL=http://192.168.50.2:1234
IMAGE_GEN_MODEL=

# ---------------------------------------------------------------------------
# aichat-mcp: web_search engines
# ---------------------------------------------------------------------------
# SearXNG is included as aichat-searxng in docker-compose — no key needed.
# Override if you run SearXNG on a separate host:
# SEARXNG_URL=http://aichat-searxng:8080

# Brave Search JSON API (optional — free tier: 2000 req/month).
# Sign up at https://api.search.brave.com/ and paste your key here:
# BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# aichat-whatsapp (optional bot)
# ---------------------------------------------------------------------------
BOT_NAME=AI Assistant
MAX_HISTORY=20
MAX_TOOL_ITER=5
MAX_TOKENS=1024
ALLOW_GROUPS=false

# ---------------------------------------------------------------------------
# Service URLs (override when running services on non-default hosts/ports)
# ---------------------------------------------------------------------------
# These are set inside docker-compose.yml using internal hostnames.
# Override here if you run any service outside of Docker.

# DATABASE_URL=postgresql://aichat:aichat@localhost:5432/aichat
# MEMORY_URL=http://localhost:8091/memory
# RESEARCH_URL=http://localhost:8091/research
# GRAPH_URL=http://localhost:8091/graph
# PLANNER_URL=http://localhost:8091/planner
# JOB_URL=http://localhost:8091/jobs
# VECTOR_URL=http://localhost:6333
# VIDEO_URL=http://localhost:8099
# OCR_URL=http://localhost:8099/ocr
# DOCS_URL=http://localhost:8101
# PDF_URL=http://localhost:8101/pdf
# TOOLKIT_URL=http://localhost:8095
