# =============================================================================
# Vision Stack Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before starting the stack.
#
# inference.yml (runs on RTX 3090 workstation — WSL2 Ubuntu at 100.91.44.100):
#   - compreface-postgres
#   - compreface
#   - triton
#   - vision-router
#
# mcp.yml (runs on Fedora server, alongside aichat stack):
#   - aichat-vision-mcp        (MCP bridge — always on)
#   - aichat-compreface-local  (CPU fallback — starts locally for HA)
#   - aichat-compreface-local-db
# =============================================================================

# RTX 3090 workstation — LAN IP
RTX_HOST=192.168.50.2

# ---------------------------------------------------------------------------
# CompreFace (inference.yml)
# ---------------------------------------------------------------------------
# PostgreSQL password for the internal CompreFace database
COMPREFACE_DB_PASSWORD=compreface_secret

# CompreFace API key (set after first login to the CompreFace UI)
COMPREFACE_API_KEY=your-compreface-api-key

# ---------------------------------------------------------------------------
# Vision Router (inference.yml  — runs on RTX 3090 at port 8090)
# ---------------------------------------------------------------------------
# Optional API key protecting the vision-router REST API.
# Leave empty to disable authentication.
VISION_ROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Vision MCP Server env vars  (mcp.yml — VISION_ prefix)
# These are injected into the aichat-vision-mcp container.
# ---------------------------------------------------------------------------

# CompreFace connectivity (primary — RTX 3090 via Tailscale)
VISION_COMPREFACE__URL=http://192.168.50.2:8080
VISION_COMPREFACE__API_KEY=your-compreface-api-key

# Per-service API keys within CompreFace (leave empty to use the global key)
VISION_COMPREFACE__RECOGNITION_API_KEY=
VISION_COMPREFACE__DETECTION_API_KEY=
VISION_COMPREFACE__VERIFICATION_API_KEY=

# CompreFace behaviour tuning
VISION_COMPREFACE__TIMEOUT_S=30.0
VISION_COMPREFACE__MAX_FILE_SIZE_MB=10.0
VISION_COMPREFACE__DET_PROB_THRESHOLD=0.8
VISION_COMPREFACE__SIMILARITY_THRESHOLD=0.85
VISION_COMPREFACE__LIMIT=5

# Vision Router connectivity (from MCP server → RTX 3090 via Tailscale)
VISION_ROUTER__URL=http://192.168.50.2:8090
VISION_ROUTER__API_KEY=
VISION_ROUTER__TIMEOUT_S=60.0

# MCP server itself
VISION_SERVER__PORT=8097
VISION_SERVER__LOG_LEVEL=INFO

# Feature flags
VISION_ENABLE_COMPREFACE=true
VISION_ENABLE_TRITON=true
VISION_ENABLE_URL_INPUT=true
VISION_ENABLE_EMBEDDINGS=true

# ---------------------------------------------------------------------------
# Vision Router env vars  (inference.yml — ROUTER_ prefix)
# These are injected into the vision-router container.
# ---------------------------------------------------------------------------
ROUTER_TRITON__URL=http://localhost:8000
ROUTER_LOG_LEVEL=INFO
ROUTER_API_KEY=
ROUTER_PORT=8090

# ---------------------------------------------------------------------------
# Local CompreFace fallback (mcp.yml — activated when RTX host unreachable)
# ---------------------------------------------------------------------------
# Postgres password for the local fallback CompreFace database
LOCAL_COMPREFACE_DB_PASSWORD=compreface_local_secret

# Fallback behaviour
VISION_FALLBACK__ENABLED=true
VISION_FALLBACK__COMPREFACE_URL=http://aichat-compreface-local:8080
# Leave empty to reuse COMPREFACE_API_KEY; set explicitly if different
VISION_FALLBACK__COMPREFACE_API_KEY=
VISION_FALLBACK__HEALTH_CHECK_INTERVAL_S=30
